<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Hotel Voucher</title>

<style>
body { font-family: Arial, sans-serif; background: #e9ecef; margin: 0; }
.wrapper { width: 1100px; margin: 30px auto; background: #fff; padding: 30px 40px; border-radius: 6px; }

.top-header { display: flex; justify-content: space-between; align-items: center; }

.voucher-title { font-size: 28px; letter-spacing: 2px; color: #333; }
.voucher-id { font-size: 20px; margin-top: 5px; }
.voucher-id span { background: #1abc9c; color: #fff; padding: 2px 6px; }

.center-logo img { height: 90px; }
.right-logo img { height: 90px; }

.divider { margin: 25px 0; border-top: 1px solid #ddd; }

.info-row { display: flex; justify-content: space-between; font-size: 14px; margin-bottom: 10px; }
.info-left div, .info-right div { margin-bottom: 6px; }

.section-title {
    background: #f1f3f5;
    color: #0b6fa4;
    text-align: center;
    padding: 8px;
    margin: 25px 0 10px;
    font-size: 20px;
    letter-spacing: 1px;
}

table { width: 100%; border-collapse: collapse; font-size: 13px; }
th { text-align: left; padding: 8px; border-bottom: 1px solid #ccc; background: #fafafa; }
td { padding: 8px; border-bottom: 1px solid #eee; }

.total-nights { text-align: center; margin-top: 10px; font-size: 14px; }

.flight-wrapper { display: flex; justify-content: space-between; margin-top: 15px; }
.flight-box { width: 48%; }

.qr-box { text-align: center; margin-top: 20px; }

.print-btn { text-align: right; margin-top: 30px; }
.print-btn button { background: #0b6fa4; color: #fff; border: none; padding: 8px 15px; cursor: pointer; }
</style>
</head>

<body>

<div class="wrapper">

    <p id="pageUrl"></p>
    <script>
        document.getElementById('pageUrl').textContent = window.location.href;
    </script>
    
    <!-- Header -->
    <div class="top-header">
        <div>
            <div class="voucher-title">HOTEL VOUCHER
            </div>
            <div class="voucher-id">
                <% const parts = voucher.voucherNo.split('-'); %>
                <span><%= parts[0] %></span>-<%= parts[1] %>
            </div>
        </div>

        <div class="center-logo">
            <% if(company.logo){ %>
                <img src="<%= company.logo %>" /><br/>
                <img src="/images/verified.jpeg"
				alt="Verified"
				style="width:100px; opacity:0.9;" />
            <% } %>
        </div>

        <div class="right-logo">
            <% if(foreignCompany.logo){ %>
            <img src="<%= foreignCompany.logo %>" />
        <% } %>
        </div>
    </div>

    <div class="divider"></div>

    <!-- Info Section -->
    <div class="info-row">
        <div class="info-left">
            <div><strong>Customer:</strong> <%= company.name %></div>
            <div><strong>Family Head:</strong> <%= familyHead %></div>
            <div><strong>Package:</strong> Custom</div>
            <div>
                <strong>PAX:</strong>
                <%= customers.length %>
                (A:<%= customers.filter(c => c.paxType !== 'children').length %>,
                 C:<%= customers.filter(c => c.paxType === 'children').length %>,
                 I:<%= customers.filter(c => c.paxType === 'infant').length %>)
            </div>
        </div>

        <div class="info-right">
            <div><strong>Voucher Date:</strong> <%= voucher.date %></div>
            <div><strong>Status:</strong> Approved</div>
        </div>
    </div>

    <!-- Mutamers -->
    <div class="section-title">Mutamers</div>

    <table>
        <tr>
            <th>Passport</th>
            <th>Mutamer Name</th>
            <th>Gender</th>
            <th>PAX</th>
            <th>Bed</th>
            <th>Visa</th>
            <th>PNR</th>
        </tr>

        <% customers.forEach(c => { %>
        <tr>
            <td><%= c.passport %></td>
            <td><%= c.name %></td>
            <td><%= c.gender %></td>
            <td><%= c.paxType %></td>
            <td><%= c.beds %></td>
            <td><%= c.visaNumber %></td>
            <td><%= c.pnr %></td>
        </tr>
        <% }) %>
    </table>

    <!-- Accommodation -->
    <div class="section-title">Accommodation</div>

    <table>
        <tr>
            <th>Hotel Name</th>
            <th>Room Type</th>
            <th>Confirm #</th>
            <th>Checkin</th>
            <th>Checkout</th>
            <th>Nights</th>
            <th>Meal Plan</th>
        </tr>

        <% hotels.forEach(h => { %>
        <tr>
            <td><%= h.name %></td>
            <td><%= h.roomType %></td>
            <td><%= h.confirmNo %></td>
            <td><%= h.checkIn %></td>
            <td><%= h.checkOut %></td>
            <td><%= h.nights %></td>
            <td><%= h.mealPlan %></td>
        </tr>
        <% }) %>
    </table>

    <div class="total-nights">
        <strong>Total Nights:</strong>
        <%= hotels.reduce((sum, h) => sum + h.nights, 0) %>
    </div>

    <!-- Transport -->
    <div class="section-title">Transport / Services</div>

    <table>
        <tr>
            <th>Type</th>
            <th>Route</th>
        </tr>

        <% transports.forEach(t => { %>
        <tr>
            <td><%= t.type %></td>
            <td><%= t.route %></td>
        </tr>
        <% }) %>
    </table>

    <!-- Flights -->
    <div class="flight-wrapper">

        <div class="flight-box">
            <div class="section-title">Departure (Pakistan to KSA)</div>
            <table>
                <tr>
                    <th>Flight</th>
                    <th>Sector</th>
                    <th>Departure</th>
                    <th>Arrival</th>
                </tr>
                <tr>
                    <td><%= departureFlight.flightNo %></td>
                    <td><%= departureFlight.fromCity %> - <%= departureFlight.toCity %></td>
                    <td><%= departureFlight.date %> - <%= departureFlight.takeoff %></td>
                    <td><%= departureFlight.date %> - <%= departureFlight.landing %></td>
                </tr>
            </table>
        </div>

        <div class="flight-box">
            <div class="section-title">Arrival (KSA to PAK)</div>
            <table>
                <tr>
                    <th>Flight</th>
                    <th>Sector</th>
                    <th>Departure</th>
                    <th>Arrival</th>
                </tr>
                <tr>
                    <td><%= arrivalFlight.flightNo %></td>
                    <td><%= arrivalFlight.fromCity %> - <%= arrivalFlight.toCity %></td>
                    <td><%= arrivalFlight.date %> - <%= arrivalFlight.takeoff %></td>
                    <td><%= arrivalFlight.date %> - <%= arrivalFlight.landing %></td>
                </tr>
            </table>
        </div>

    </div>

    <!-- QR -->
    <!-- <div class="qr-box">
        <img src="<%= qrImage %>" width="140" />
    </div> -->

    <!-- Notes Text -->
    <div style="white-space: pre-line; width:80%;">
        <strong>Note:</strong><br>
        <%= notes %>
    </div>

    <div class="print-btn">
        <button onclick="window.print()">Print</button>
    </div>

</div>

</body>
</html>