<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Hotel Voucher</title>

<style>

/* Force A4 Portrait */
@page {
    size: A4 portrait;
    margin: 12mm;
}

body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: #e9ecef;
    margin: 0;
    color: #333;
}

.wrapper {
    width: 100%;
    max-width: 800px;
    margin: 20px auto;
    background: #fff;
    padding: 30px 40px;
    border-radius: 8px;
    box-sizing: border-box;
    border: 1px solid #ccc;
}

/* Header */
.header {
    text-align: center;
    margin-bottom: 20px;
}

.header .company-name {
    font-size: 26px;
    font-weight: bold;
    color: #0b6fa4;
}

.header .company-address {
    font-size: 14px;
    color: #555;
    margin-top: 4px;
}

.top-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 20px;
    gap: 20px;
}

.voucher-info {
    text-align: left;
    flex: 1;
}

.voucher-title {
    font-size: 28px;
    letter-spacing: 2px;
    font-weight: bold;
    color: #333;
}

.voucher-id {
    font-size: 18px;
    margin-top: 5px;
    font-weight: bold;
}

.voucher-id span {
    background: #1abc9c;
    color: #fff;
    padding: 3px 8px;
    border-radius: 4px;
}

/* Logo & Verified */
.center-logo img {
    object-fit: contain;
    max-height: 90px;
    max-width: 150px;
    margin-top: 10px;
}

.middle-verified {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    min-width: 180px;
    margin-top: 8px;
}

.right-logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    flex: 1;
}

.right-logo img {
    object-fit: contain;
    max-height: 120px;
    max-width: 200px;
    margin-top: 10px;
}

.verified-box {
    /* border: 3px solid #0b6fa4; */
    padding: 18px 34px;
    font-weight: bold;
    color: #0b6fa4;
    /* background: #e0f0ff; */
    border-radius: 10px;
    font-size: 28px;
    text-align: center;
    min-width: 170px;

    /* Tilt text box */
    display: inline-block;
    transform: rotate(-35deg); /* -35deg ya -40deg try kar lo */
    transform-origin: center;
}

/* Divider */
.divider {
    margin: 25px 0;
    border-top: 2px solid #0b6fa4;
}

/* Info Section */
.info-row {
    display: flex;
    justify-content: space-between;
    font-size: 14px;
    margin-bottom: 15px;
}

.info-left div,
.info-right div {
    margin-bottom: 6px;
}

/* Sections */
.section-title {
    background: #0b6fa4;
    color: #fff;
    text-align: center;
    padding: 8px;
    margin: 25px 0 10px;
    font-size: 18px;
    letter-spacing: 1px;
    border-radius: 4px;
}

/* Tables */
table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
}

table th, table td {
    padding: 10px;
    border: 1px solid #ccc;
}

table th {
    background: #f1f3f5;
    color: #0b6fa4;
    text-align: left;
}

/* Total nights */
.total-nights {
    text-align: center;
    margin-top: 10px;
    font-size: 14px;
    font-weight: bold;
}

/* Flight wrapper */
.flight-wrapper {
    display: flex;
    justify-content: space-between;
    margin-top: 15px;
}

.flight-box {
    width: 48%;
}

/* QR Box */
.qr-box {
    text-align: center;
    margin-top: 20px;
}

/* Notes / Links */
.notes {
    white-space: pre-line;
    margin-top: 20px;
    font-weight: 600;
    line-height: 1.4;
}

.notes a {
    font-weight: 500;
    color: #0b6fa4;
    text-decoration: underline;
}

/* Print Button */
.print-btn {
    text-align: right;
    margin-top: 30px;
}

.print-btn button {
    background: #0b6fa4;
    color: #fff;
    border: none;
    padding: 8px 15px;
    cursor: pointer;
    border-radius: 4px;
}

/* Hide Print Button in PDF */
@media print {
    .print-btn {
        display: none;
    }
}

</style>
</head>

<body>

<div class="wrapper">

    <!-- Company Header -->
    <div class="header">
        <div class="company-name"><%= company.name %></div>
        <div class="company-address">
            Shaheen View Appartments, Office #7, Mezzanine floor, Shaheen View, off Shahrah e Faisal, Block-6, P.E.C.H.S., Karachi, 76800
        </div>
    </div>

    <!-- Voucher Info & Logos -->
    <div class="top-header">

        <!-- Left: Voucher + Company Logo -->
        <div class="voucher-info">
            <div class="voucher-title">HOTEL VOUCHER</div>
            <div class="voucher-id">
                <% const parts = voucher.voucherNo.split('-'); %>
                <span><%= parts[0] %></span>-<%= parts[1] %>
            </div>
            <% if(company.logo){ %>
                <div class="center-logo"><img src="<%= company.logo %>" /></div>
            <% } %>
        </div>

        <!-- Middle: Verified -->
        <div class="middle-verified">
            <div class="verified-box">VERIFIED</div>
        </div>

        <!-- Right: Foreign Company Logo -->
        <div class="right-logo">
            <% if(foreignCompany.logo){ %>
                <img src="<%= foreignCompany.logo %>" />
            <% } %>
        </div>
    </div>

    <div class="divider"></div>

    <!-- Info Section -->
    <div class="info-row">
        <div class="info-left">
            <div><strong>Family Head:</strong> <%= familyHead %></div>
            <div><strong>Package:</strong> Custom</div>
            <div>
                <strong>PAX:</strong> <%= customers.length %>
                (A:<%= customers.filter(c => c.paxType !== 'children').length %>,
                 C:<%= customers.filter(c => c.paxType === 'children').length %>,
                 I:<%= customers.filter(c => c.paxType === 'infant').length %>)
            </div>
        </div>

        <div class="info-right">
            <div><strong>Voucher Date:</strong> <%= voucher.date %></div>
            <div><strong>Status:</strong> Approved</div>
        </div>
    </div>

    <!-- Mutamers -->
    <div class="section-title">Mutamers</div>
    <table>
        <tr>
            <th>Passport</th>
            <th>Name</th>
            <th>Gender</th>
            <th>PAX</th>
            <th>Bed</th>
            <th>Visa</th>
            <th>PNR</th>
        </tr>
        <% customers.forEach(c => { %>
        <tr>
            <td><%= c.passport %></td>
            <td><%= c.name %></td>
            <td><%= c.gender %></td>
            <td><%= c.paxType %></td>
            <td><%= c.beds %></td>
            <td><%= c.visaNumber %></td>
            <td><%= c.pnr %></td>
        </tr>
        <% }) %>
    </table>

    <!-- Hotels -->
    <div class="section-title">Hotels</div>
    <table>
        <tr>
            <th>Hotel Name</th>
            <th>Room Type</th>
            <th>Confirm #</th>
            <th>Checkin</th>
            <th>Checkout</th>
            <th>Nights</th>
            <th>Meal Plan</th>
        </tr>
        <% hotels.forEach(h => { %>
        <tr>
            <td><%= h.name %></td>
            <td><%= h.roomType %></td>
            <td><%= h.confirmNo %></td>
            <td><%= h.checkIn %></td>
            <td><%= h.checkOut %></td>
            <td><%= h.nights %></td>
            <td><%= h.mealPlan %></td>
        </tr>
        <% }) %>
    </table>
    <div class="total-nights">
        <strong>Total Nights:</strong> <%= hotels.reduce((sum, h) => sum + h.nights, 0) %>
    </div>

    <!-- Transport / Services -->
    <div class="section-title">Transport / Services</div>
    <table>
        <tr>
            <th>Type</th>
            <th>Route</th>
        </tr>
        <% transports.forEach(t => { %>
        <tr>
            <td><%= t.type %></td>
            <td><%= t.route %></td>
        </tr>
        <% }) %>
    </table>

    <!-- Flights -->
    <div class="flight-wrapper">
        <div class="flight-box">
            <div class="section-title">Departure (PAK → KSA)</div>
            <table>
                <tr>
                    <th>Flight</th><th>Sector</th><th>Departure</th><th>Arrival</th>
                </tr>
                <tr>
                    <td><%= departureFlight.flightNo %></td>
                    <td><%= departureFlight.fromCity %> - <%= departureFlight.toCity %></td>
                    <td><%= departureFlight.date %> - <%= departureFlight.takeoff %></td>
                    <td><%= departureFlight.date %> - <%= departureFlight.landing %></td>
                </tr>
            </table>
        </div>

        <div class="flight-box">
            <div class="section-title">Arrival (KSA → PAK)</div>
            <table>
                <tr>
                    <th>Flight</th><th>Sector</th><th>Departure</th><th>Arrival</th>
                </tr>
                <tr>
                    <td><%= arrivalFlight.flightNo %></td>
                    <td><%= arrivalFlight.fromCity %> - <%= arrivalFlight.toCity %></td>
                    <td><%= arrivalFlight.date %> - <%= arrivalFlight.takeoff %></td>
                    <td><%= arrivalFlight.date %> - <%= arrivalFlight.landing %></td>
                </tr>
            </table>
        </div>
    </div>

    <!-- Notes -->
    <div class="notes" style="white-space: pre-line; margin-top:20px; font-weight: bold; line-height:1.5; font-size:14px;">
        <strong>Note:</strong><br>
        MAKKAH HOTEL:- Uzair 0548335007 (Day) Tariq 0549306332 (Night)\
        MEDINAH HOTEL:- MR. ARSALAN +966544809146
        Transport Contact: +966500000000
        <%= notes %>
    </div>

    <!-- Print Button -->
    <div class="print-btn">
        <button onclick="window.print()">Print</button>
    </div>

    <p id="pageUrl" style="text-decoration: underline; word-break: break-word; font-size: 11px; font-family: Arial, Helvetica, sans-serif; font-weight: 400; color: #666; margin-top: 8px;"></p>
    <script>
        document.getElementById('pageUrl').textContent = window.location.href;
    </script>
    
    <style>
    .notes a{
        font-weight: bold;
        color: #0b6fa4;
        text-decoration: underline;
    }
    </style>

</div>

</body>
</html>