<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Hotel Voucher</title>
    <style>
        body { font-family: Arial, sans-serif; background: #f4f4f4; }
        .page { width: 900px; margin: 30px auto; background: #fff; padding: 30px; border: 1px solid #ccc; }
        .header { position: relative; text-align: center; margin-bottom: 20px; }

        .header img.left-logo {
            position: absolute; left: 0; top: 0;
            width: 80px; height: 80px; border: 1px solid #000;
        }

        .header img.right-logo {
            position: absolute; right: 0; top: 0;
            width: 180px; height: 80px; border: 1px solid #000;
        }

        h2, h3 { margin: 5px 0; }

        table { width: 100%; border-collapse: collapse; margin-bottom: 15px; }
        table, th, td { border: 1px solid #000; text-align:center; }
        th, td { padding: 6px; font-size: 13px; }

        .section-title { text-align: center; font-weight: bold; margin: 15px 0 5px; }
        .note { font-size: 13px; margin-top: 15px; white-space: pre-line; }

        
    </style>
</head>
<body>

<div class="page">

    <!-- Header -->
    <div class="header">
        <% if(company.logo){ %><img src="<%= company.logo %>" class="left-logo" /><% } %>
        <% if(foreignCompany.logo){ %><img src="<%= foreignCompany.logo %>" class="right-logo" /><% } %>
        
        <h2><%= company.name %></h2>
        <h5 class="company-address">
            Shaheen View Appartments, Office #7, Mezzanine floor,<br/> Shaheen View, off Shahrah e Faisal, Block-6 Block 6 P.E.C.H.S., Karachi, 76800
        </h5>
        <h3>Hotel Voucher</h3>
    </div>
	<br/>
    <!-- Voucher Info Section -->
	<table>
		<tr>
			<td><strong>IATA:</strong></td>
			<td><%= company.name %></td>

			<td><strong>Voucher No:</strong></td>
			<td><%= voucher.voucherNo %></td>

			<td><strong>Branch:</strong></td>
			<td>LHE</td>
		</tr>

		<tr>
			<td><strong>Saudi Company:</strong></td>
			<td><%= foreignCompany.name %></td>

			<td><strong>Date:</strong></td>
			<td><%= voucher.date %></td>

			<td></td>
			<td></td>
		</tr>

		<tr>
			<td><strong>Package:</strong></td>
			<td>Custom</td>

			<td><strong>Manual No:</strong></td>
			<td>-</td>

			<td><strong>Group #:</strong></td>
			<td>901052165</td>
		</tr>

		<tr>
			<td><strong>Family Head:</strong></td>
			<td><%= familyHead %></td>

			<td><strong>Total PAX:</strong></td>
			<td><%= customers.length %></td>

			<td><strong>Whatsapp:</strong></td>
			<td>-</td>
		</tr>
	</table>

    <!-- Pilgrims -->
    <div class="section-title">Pilgrims Details</div>

    <table>
        <tr>
            <th>Name</th>
            <th>Gender</th>
            <th>Passport</th>
            <th>Visa</th>
            <th>PNR</th>
        </tr>

        <% customers.forEach(customer => { %>
            <tr>
                <td><%= customer.name %></td>
                <td><%= customer.gender %></td>
                <td><%= customer.passport %></td>
                <td><%= customer.visaNumber %></td>
                <td><%= customer.pnr %></td>
            </tr>
        <% }) %>

    </table>

    <!-- Accommodation -->
    <div class="section-title">Accommodation Details</div>

    <table>
        <tr>
            <th>Hotel</th>
            <th>Confirm No</th>
            <th>City</th>
            <th>Room Type</th>
            <th>Meal</th>
            <th>Check In</th>
            <th>Check Out</th>
            <th>Nights</th>
        </tr>

        <% hotels.forEach(hotel => { %>
            <tr>
                <td><%= hotel.name %></td>
                <td><%= hotel.confirmNo %></td>
                <td><%= hotel.city %></td>
                <td><%= hotel.roomType %></td>
                <td><%= hotel.mealPlan %></td>
                <td><%= hotel.checkIn %></td>
                <td><%= hotel.checkOut %></td>
                <td><%= hotel.nights %></td>
            </tr>
        <% }) %>

    </table>

    <!-- Flights -->
    <div class="section-title">Flight Details</div>

    <div style="display: flex; justify-content: space-between; align-items: flex-start;">

        <table style="width: 78%;">
            <tr>
                <th colspan="5" style="text-align:center;">Departure from Pakistan to KSA</th>
            </tr>
            <tr>
                <th>Flight</th>
                <th>Date</th>
                <th>Route</th>
                <th>Departure</th>
                <th>Arrival</th>
            </tr>
            <tr>
                <td><%= departureFlight.flightNo %></td>
                <td><%= departureFlight.date %></td>
                <td><%= departureFlight.fromCity %> - <%= departureFlight.toCity %></td>
                <td><%= departureFlight.takeoff %></td>
                <td><%= departureFlight.landing %></td>
            </tr>

            <tr>
                <th colspan="5" style="text-align:center;">Departure from KSA to Pakistan</th>
            </tr>
            <tr>
                <th>Flight</th>
                <th>Date</th>
                <th>Route</th>
                <th>Departure</th>
                <th>Arrival</th>
            </tr>
            <tr>
                <td><%= arrivalFlight.flightNo %></td>
                <td><%= arrivalFlight.date %></td>
                <td><%= arrivalFlight.fromCity %> - <%= arrivalFlight.toCity %></td>
                <td><%= arrivalFlight.takeoff %></td>
                <td><%= arrivalFlight.landing %></td>
            </tr>
        </table>

        <!-- Single QR -->
        <div style="width: 18%; text-align: center;">
            <img src="<%= qrImage %>"
                 style="width:140px; height:140px; border:1px solid #000;" />
        </div>

    </div>

    <!-- Notes -->
    <div class="note">
        <strong>Note:</strong><br>
        MAKKAH HOTEL:- Uzair 0548335007 (Day) Tariq 0549306332 (Night)\
        MEDINAH HOTEL:- MR. ARSALAN +966544809146
        Transport Contact: +966500000000
        <%= notes %>
    </div>

</div>

</body>
</html>