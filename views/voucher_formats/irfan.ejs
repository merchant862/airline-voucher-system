<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Service Voucher</title>

<style>
body{
    font-family: Arial, "Noto Naskh Arabic", "Amiri", Tahoma, sans-serif;
    background:#f2f2f2;
    margin:0;
}

.wrapper{
    width:1000px;
    margin:20px auto;
    background:#fff;
    padding:20px;
    border:1px solid #000;
}

.header-table{
    width:100%;
    border-collapse:collapse;
    margin-bottom:10px;
}

.header-table td{
    border:none;
    vertical-align:middle;
}

.logo{
    height:70px;
}

.center-title{
    text-align:center;
}

.center-title h2{
    margin:0;
    font-size:20px;
}

.service-title{
    text-align:center;
    font-weight:bold;
    letter-spacing:3px;
    margin-top:5px;
}

table{
    width:100%;
    border-collapse:collapse;
    font-size:12px;
    margin-top:5px;
}

table, th, td{
    border:1px solid #000;
}

th, td{
    padding:5px;
}

.section-heading{
    text-align:center;
    font-weight:bold;
    margin-top:10px;
    letter-spacing:2px;
}

.center{text-align:center;}
.right{text-align:right;}

.qr-wrapper{
    margin-top:10px;
}

.note{
    font-size:11px;
    margin-top:8px;
    white-space:pre-line;
}

.arabic-block{
    direction:rtl;
    text-align:right;
    font-size:13px;
    margin-top:8px;
    font-family: "Noto Naskh Arabic","Amiri",Tahoma,Arial;
}

.important{
    margin-top:10px;
    border-top:2px solid #000;
    padding-top:5px;
    font-size:12px;
}
</style>
</head>

<body>

<div class="wrapper">

<!-- HEADER -->
<table class="header-table">
<tr>
<td width="20%">
    <img src="<%= company.logo %>" class="logo">
</td>

<td width="60%" class="center-title">
    <h2><%= company.name.toUpperCase() %></h2>
    <div>Address: Office # 2 Time Tower Abdullah Haroon Road, Karachi, Pakistan.</div>
    <div class="service-title">SERVICE VOUCHER</div>
</td>

<td width="20%" class="right">
    <img src="<%= foreignCompany.logo %>" class="logo">
</td>
</tr>
</table>

<!-- VOUCHER INFO -->
<table>
<tr>
<td><strong>UMRAH COMPANY</strong></td>
<td><%= foreignCompany.name %></td>
<td><strong>HOTEL VOUCHER#</strong></td>
<td><%= voucher.voucherNo %></td>
<td><strong>V-DATE</strong></td>
<td><%= voucher.date %></td>
</tr>
<tr>
<td><strong>Executive Agent</strong></td>
<td colspan="5">PKG CATEGORY / DAZ 0%</td>
</tr>
</table>

<!-- PARTY DETAILS -->
<div class="section-heading">PARTY DETAILS</div>

<table>
<tr>
<th>SR</th>
<th>PAX NAME(S)</th>
<th>PASSPORT NO.</th>
<th>GROUP</th>
<th>VISA NO.</th>
</tr>

<% customers.forEach((c,i)=>{ %>
<tr>
<td class="center"><%= i+1 %></td>
<td><%= c.name %></td>
<td><%= c.passport %></td>
<td>901052165</td>
<td><%= c.visaNumber %></td>
</tr>
<% }) %>

<tr>
<td colspan="5" class="center">
GENTS: <%= customers.filter(c=>c.gender==='Male').length %> &nbsp;&nbsp;
LADIES: <%= customers.filter(c=>c.gender==='Female').length %> &nbsp;&nbsp;
CHILDREN: <%= customers.filter(c=>c.paxType==='Child').length %> &nbsp;&nbsp;
TOTAL PAX: <%= customers.length %>
</td>
</tr>
</table>

<!-- ACCOMMODATION -->
<div class="section-heading">ACCOMMODATION DETAILS</div>

<table>
<tr>
<th>CITY</th>
<th>HOTEL NAME</th>
<th>ROOM</th>
<th>ROOM TYPE</th>
<th>CHECK IN</th>
<th>CHECK OUT</th>
<th>NIGHTS</th>
</tr>

<% hotels.forEach(h=>{ %>
<tr>
<td><%= h.city %></td>
<td><%= h.name %></td>
<td class="center">1</td>
<td><%= h.roomType %></td>
<td><%= h.checkIn %></td>
<td><%= h.checkOut %></td>
<td class="center"><%= h.nights %></td>
</tr>
<% }) %>

<tr>
<td colspan="6" class="right"><strong>Total Nights</strong></td>
<td class="center">
<%= hotels.reduce((sum,h)=>sum+h.nights,0) %>
</td>
</tr>
</table>

<!-- TRANSPORT -->
<div class="section-heading">TRANSPORTATION DETAILS</div>

<table>
<tr>
<th>TYPE</th>
<th>ROUTE</th>
</tr>

<% transports.forEach(t=>{ %>
<tr>
<td><%= t.type %></td>
<td><%= t.route %></td>
</tr>
<% }) %>
</table>

<!-- FLIGHT DETAILS -->
<div class="section-heading">FLIGHT DETAILS</div>

<table>
<tr>
<th>FLIGHT</th>
<th>FROM</th>
<th>TO</th>
<th>DEPARTURE</th>
<th>ARRIVAL</th>
</tr>
<tr>
<td><%= departureFlight.flightNo %></td>
<td><%= departureFlight.fromCity %></td>
<td><%= departureFlight.toCity %></td>
<td><%= departureFlight.date %> - <%= departureFlight.takeoff %></td>
<td><%= departureFlight.date %> - <%= departureFlight.landing %></td>
</tr>
<tr>
<td><%= arrivalFlight.flightNo %></td>
<td><%= arrivalFlight.fromCity %></td>
<td><%= arrivalFlight.toCity %></td>
<td><%= arrivalFlight.date %> - <%= arrivalFlight.takeoff %></td>
<td><%= arrivalFlight.date %> - <%= arrivalFlight.landing %></td>
</tr>
</table>

<!-- QR + CONTACT -->
<table class="qr-wrapper">
<tr>
<td width="70%">
<strong>CONTACT NO.</strong><br>
MR. FAISAL 0092-3422614769 (WHATSAPP)<br>
MR. ADNAN 0092-3333153594 (WHATSAPP)
</td>

<td width="30%" class="center">
<img src="<%= qrImage %>" width="160"><br>
<strong>AUTHORIZED<br>DAR-AL-SALAM GROUP</strong>
</td>
</tr>
</table>

<!-- NOTES -->
<div class="note">
<strong>Note:</strong><br>
<%= notes %>
</div>

<!-- ARABIC BLOCK -->
<div class="arabic-block">
تنبيه هام: يمنع تسليم جواز السفر لأي شخص داخل المملكة العربية السعودية سواء وكيل أو شركة نقل.
يرجى التواصل مع وكيل السفر الباكستاني في حال حدوث أي مشكلة.
</div>

<div class="important">
<strong>IMPORTANT NOTICE:</strong>
Passengers are requested not to hand over your passport to anyone in Saudi Arabia either agent or transporter provider.
</div>

</div>

</body>
</html>